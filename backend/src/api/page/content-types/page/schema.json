{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "Static HMS page content"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "section": {
      "type": "string"
    },
    "summary": {
      "type": "text"
    },
    "body": {
      "type": "richtext"
    },
    "links": {
      "type": "json"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
